class Solution {
    private int getWaviness(int x) {
        String s = Integer.toString(x);
        int n = s.length();

        int cnt = 0;
        for (int i = 1; i < n - 1; i++) {
            char cur = s.charAt(i);
            char left = s.charAt(i - 1);
            char right = s.charAt(i + 1);

            if ((cur > left && cur > right) ||
                (cur < left && cur < right)) {
                cnt++;
            }
        }
        return cnt;
    }

    public int totalWaviness(int num1, int num2) {
        int ans = 0;

        for (int x = num1; x <= num2; x++) {
            ans += getWaviness(x);
        }

        return ans;
    }
}
