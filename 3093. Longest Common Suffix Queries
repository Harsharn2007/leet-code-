class Solution {
    
    class TrieNode {
        TrieNode[] child = new TrieNode[26];
        int index;
        int len;
        
        TrieNode(int idx, int l) {
            index = idx;
            len = l;
        }
    }
    
    public int[] stringIndices(String[] wordsContainer, String[] wordsQuery) {
        
        // Find index of smallest word
        int minIdx = 0;
        for (int i = 1; i < wordsContainer.length; i++) {
            if (wordsContainer[i].length() < wordsContainer[minIdx].length()) {
                minIdx = i;
            }
        }
        
        TrieNode root = new TrieNode(minIdx, wordsContainer[minIdx].length());
        
        // Insert all container words in reverse order
        for (int i = 0; i < wordsContainer.length; i++) {
            insert(root, wordsContainer[i], i);
        }
        
        int[] ans = new int[wordsQuery.length];
        
        // Process queries
        for (int i = 0; i < wordsQuery.length; i++) {
            ans[i] = search(root, wordsQuery[i]);
        }
        
        return ans;
    }
    
    private void insert(TrieNode root, String word, int idx) {
        TrieNode node = root;
        int n = word.length();
        
        // Update best index at root
        if (n < node.len) {
            node.len = n;
            node.index = idx;
        }
        
        for (int i = n - 1; i >= 0; i--) {
            int c = word.charAt(i) - 'a';
            
            if (node.child[c] == null) {
                node.child[c] = new TrieNode(idx, n);
            }
            
            node = node.child[c];
            
            // Store shortest word index
            if (n < node.len) {
                node.len = n;
                node.index = idx;
            }
        }
    }
    
    private int search(TrieNode root, String word) {
        TrieNode node = root;
        
        for (int i = word.length() - 1; i >= 0; i--) {
            int c = word.charAt(i) - 'a';
            
            if (node.child[c] == null) {
                break;
            }
            
            node = node.child[c];
        }
        
        return node.index;
    }
}
