class Solution {
    public int maxDistance(int[] nums) {
        int n = nums.length;
        int maxDist = 0;

        for (int i = 0; i < n; i++) {
            if (nums[i] != nums[n - 1]) {
                maxDist = Math.max(maxDist, n - 1 - i);
            }
            if (nums[i] != nums[0]) {
                maxDist = Math.max(maxDist, i);
            }
        }

        return maxDist;
    }
}
