class Solution {
    
    // Function to calculate sum of digits
    int digitSum(int n) {
        int sum = 0;
        
        while (n > 0) {
            sum += n % 10;
            n /= 10;
        }
        
        return sum;
    }
    
    public int minElement(int[] nums) {
        int min = Integer.MAX_VALUE;
        
        for (int num : nums) {
            int sum = digitSum(num);
            min = Math.min(min, sum);
        }
        
        return min;
    }
}
