class Solution {
    public int minJumps(int[] nums) {
        int n = nums.length;
        if (n == 1) return 0;

        int maxVal = 0;
        for (int x : nums) {
            maxVal = Math.max(maxVal, x);
        }

        // Prime sieve
        boolean[] isPrime = new boolean[maxVal + 1];
        Arrays.fill(isPrime, true);

        if (maxVal >= 0) isPrime[0] = false;
        if (maxVal >= 1) isPrime[1] = false;

        for (int i = 2; i * i <= maxVal; i++) {
            if (isPrime[i]) {
                for (int j = i * i; j <= maxVal; j += i) {
                    isPrime[j] = false;
                }
            }
        }

        // divisor -> indices
        Map<Integer, List<Integer>> divMap = new HashMap<>();

        for (int i = 0; i < n; i++) {
            int x = nums[i];

            for (int d = 1; d * d <= x; d++) {
                if (x % d == 0) {

                    divMap.computeIfAbsent(d, k -> new ArrayList<>()).add(i);

                    if (d != x / d) {
                        divMap.computeIfAbsent(x / d, k -> new ArrayList<>()).add(i);
                    }
                }
            }
        }

        Queue<Integer> q = new LinkedList<>();
        int[] dist = new int[n];
        Arrays.fill(dist, -1);

        q.offer(0);
        dist[0] = 0;

        Set<Integer> usedPrime = new HashSet<>();

        while (!q.isEmpty()) {
            int i = q.poll();

            if (i == n - 1) {
                return dist[i];
            }

            // left
            if (i - 1 >= 0 && dist[i - 1] == -1) {
                dist[i - 1] = dist[i] + 1;
                q.offer(i - 1);
            }

            // right
            if (i + 1 < n && dist[i + 1] == -1) {
                dist[i + 1] = dist[i] + 1;
                q.offer(i + 1);
            }

            // prime teleport
            int val = nums[i];

            if (isPrime[val] && !usedPrime.contains(val)) {
                usedPrime.add(val);

                for (int nxt : divMap.getOrDefault(val, new ArrayList<>())) {
                    if (dist[nxt] == -1) {
                        dist[nxt] = dist[i] + 1;
                        q.offer(nxt);
                    }
                }
            }
        }

        return -1;
    }
}
