class Solution {
public:
    char processStr(string s, long long k) {
        int n = s.size();
        vector<long long> len(n + 1, 0);

        // Forward pass: compute lengths
        for (int i = 0; i < n; i++) {
            char c = s[i];

            if ('a' <= c && c <= 'z') {
                len[i + 1] = len[i] + 1;
            }
            else if (c == '*') {
                len[i + 1] = max(0LL, len[i] - 1);
            }
            else if (c == '#') {
                len[i + 1] = min((long long)1e15, len[i] * 2);
            }
            else { // '%'
                len[i + 1] = len[i];
            }
        }

        if (k >= len[n]) return '.';

        // Backward pass: trace index k
        for (int i = n - 1; i >= 0; i--) {
            char c = s[i];

            if ('a' <= c && c <= 'z') {
                if (k == len[i]) return c;
            }
            else if (c == '*') {
                // Before deletion length was len[i]
                if (len[i] > len[i + 1]) {
                    // deleted last character
                    // existing indices remain unchanged
                }
            }
            else if (c == '#') {
                long long oldLen = len[i];
                k %= oldLen;
            }
            else { // '%'
                long long L = len[i];
                k = L - 1 - k;
            }
        }

        return '.';
    }
};
