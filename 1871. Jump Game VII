class Solution {
    public boolean canReach(String s, int minJump, int maxJump) {
        int n = s.length();

        // dp[i] = true if index i can be reached
        boolean[] dp = new boolean[n];
        dp[0] = true;

        int reachable = 0;

        for (int i = 1; i < n; i++) {

            // Add new reachable position into window
            if (i - minJump >= 0 && dp[i - minJump]) {
                reachable++;
            }

            // Remove positions out of window
            if (i - maxJump - 1 >= 0 && dp[i - maxJump - 1]) {
                reachable--;
            }

            // Current position can be reached
            if (s.charAt(i) == '0' && reachable > 0) {
                dp[i] = true;
            }
        }

        return dp[n - 1];
    }
}
