class Solution {
    public int minMoves(int[] nums, int limit) {
        int[] diff = new int[2 * limit + 2];

        int n = nums.length;

        for (int i = 0; i < n / 2; i++) {
            int a = nums[i];
            int b = nums[n - 1 - i];

            int min = Math.min(a, b);
            int max = Math.max(a, b);
            int sum = a + b;

            // Initially 2 moves for all sums
            diff[2] += 2;

            // 1 move range starts
            diff[min + 1] -= 1;

            // 0 move at exact sum
            diff[sum] -= 1;

            // back to 1 move
            diff[sum + 1] += 1;

            // back to 2 moves
            diff[max + limit + 1] += 1;
        }

        int ans = Integer.MAX_VALUE;
        int curr = 0;

        for (int s = 2; s <= 2 * limit; s++) {
            curr += diff[s];
            ans = Math.min(ans, curr);
        }

        return ans;
    }
}
